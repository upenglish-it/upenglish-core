rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /audio_answers/{submissionId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /option_images/{fileName} {
      allow read, write: if request.auth != null;
    }
    match /context_audio/{resource=**} {
      allow read, write: if request.auth != null;
    }
    match /context_images/{fileName} {
      allow read, write: if request.auth != null;
    }
    match /vocab_images/{fileName} {
      allow read, write: if request.auth != null;
    }
  }
}
