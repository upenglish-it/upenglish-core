{
  "name": "isms",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "start:isms": "rimraf dist/apps/isms && nest start isms --watch",
    "build:prod:isms": "rimraf dist/apps/isms && nest build isms",
    "start:prod:isms": "node dist/apps/isms/main",
    "start:superlms": "rimraf dist/apps/superlms && nest start superlms --watch",
    "build:prod:superlms": "rimraf dist/apps/superlms && nest build superlms",
    "start:prod:superlms": "node dist/apps/superlms/main",
    "start:dev": "nest start --watch",
    "start:superstudy": "rimraf dist/apps/superstudy && nest start superstudy --watch",
    "build:prod:superstudy": "rimraf dist/apps/superstudy && nest build superstudy",
    "start:prod:superstudy": "node dist/apps/superstudy/main",
    "start": "concurrently \"yarn start:isms\" \"yarn start:superlms\" \"yarn start:superstudy\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
