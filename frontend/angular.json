{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "isms": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "less",
          "standalone": true
        },
        "@schematics/angular:pipe": {
          "standalone": true
        }
      },
      "root": "projects/isms",
      "sourceRoot": "projects/isms/src",
      "prefix": "isms",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/isms",
            "index": "projects/isms/src/index.html",
            "main": "projects/isms/src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "projects/isms/tsconfig.app.json",
            "inlineStyleLanguage": "less",
            "assets": [
              "projects/isms/src/android-chrome-192x192.png",
              "projects/isms/src/android-chrome-512x512.png",
              "projects/isms/src/apple-touch-icon.png",
              "projects/isms/src/favicon-16x16.png",
              "projects/isms/src/favicon-32x32.png",
              "projects/isms/src/favicon.ico",
              "projects/isms/src/assets",
              "projects/isms/src/firebase-messaging-sw.js",
              "projects/isms/src/manifest.json"
            ],
            "styles": ["projects/isms/src/assets/styles/styles.less"],
            "stylePreprocessorOptions": {
              "includePaths": ["node_modules/"]
            },
            "scripts": [],
            "allowedCommonJsDependencies": ["socket.io-client", "crypto-js", "lodash", "moment", "tui-calendar", "dot-object", "apexcharts", "papaparse"]
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "projects/isms/src/environments/environment.ts",
                  "with": "projects/isms/src/environments/environment.prod.ts"
                }
              ],
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "3mb",
                  "maximumError": "5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb",
                  "maximumError": "10kb"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "buildOptimizer": false,
              "optimization": false,
              "vendorChunk": true,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "isms:build:production"
            },
            "development": {
              "buildTarget": "isms:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "buildTarget": "isms:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": ["zone.js", "zone.js/testing"],
            "tsConfig": "projects/isms/tsconfig.spec.json",
            "inlineStyleLanguage": "less",
            "assets": ["projects/isms/src/favicon.ico", "projects/isms/src/assets"],
            "styles": ["projects/isms/src/styles.less"],
            "scripts": []
          }
        }
      }
    },
    "superlms": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "less"
        }
      },
      "root": "projects/superlms",
      "sourceRoot": "projects/superlms/src",
      "prefix": "slms",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/superlms",
            "index": "projects/superlms/src/index.html",
            "browser": "projects/superlms/src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "projects/superlms/tsconfig.app.json",
            "inlineStyleLanguage": "less",
            "assets": [
              "projects/superlms/src/assets",
              "projects/superlms/src/android-chrome-192x192.png",
              "projects/superlms/src/android-chrome-512x512.png",
              "projects/superlms/src/apple-touch-icon.png",
              "projects/superlms/src/favicon-16x16.png",
              "projects/superlms/src/favicon-32x32.png",
              "projects/superlms/src/favicon.ico",
              "projects/superlms/src/manifest.json"
            ],
            "styles": ["projects/superlms/src/styles.less"],
            "scripts": []
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "projects/superlms/src/environments/environment.ts",
                  "with": "projects/superlms/src/environments/environment.prod.ts"
                }
              ],
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "3mb",
                  "maximumError": "5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb",
                  "maximumError": "10kb"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "superlms:build:production"
            },
            "development": {
              "buildTarget": "superlms:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "buildTarget": "superlms:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": ["zone.js", "zone.js/testing"],
            "tsConfig": "projects/superlms/tsconfig.spec.json",
            "inlineStyleLanguage": "less",
            "assets": ["projects/superlms/src/favicon.ico", "projects/superlms/src/assets"],
            "styles": ["projects/superlms/src/styles.less"],
            "scripts": []
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
